# Resend API key used by app/api/contact/route.ts
RESEND_API_KEY=

# Verified "from" sender for outgoing contact-form emails.
# Defaults to Resend's shared test domain until keystone.systems is verified in Resend.
RESEND_FROM_EMAIL="Keystone Systems <onboarding@resend.dev>"

# Destination inbox for contact-form submissions.
# Defaults to tanner@propdog.ai until a @keystone.systems inbox exists.
CONTACT_TO_EMAIL=tanner@propdog.ai
